{
  "name": "@snowiest/theme-vars",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "build": "pnpm run check:theme && pnpm run typecheck",
    "check:theme": "node --import @swc-node/register/esm-register ./scripts/check-theme.mjs",
    "lint": "pnpm exec eslint .",
    "sync:theme": "node --import @swc-node/register/esm-register ./scripts/sync-theme.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@snowiest/eslint-config": "workspace:*",
    "eslint": "^10.2.0"
  }
}
